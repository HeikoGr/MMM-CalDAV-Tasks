{
  "name": "mmm-caldav-tasks",
  "type": "commonjs",
  "version": "1.1.5",
  "description": "MagicMirror module to display and manage CalDAV tasks (to-dos)",
  "keywords": [
    "magicmirror",
    "magicmirror2",
    "magicmirror-module",
    "caldav",
    "tasks",
    "todo",
    "nextcloud"
  ],
  "main": "MMM-CalDAV-Tasks.js",
  "author": "HeikoGr",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeikoGr/MMM-CalDAV-Tasks.git"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:spelling": "cspell .",
    "check": "node check.js ../../config/config.js || true",
    "debug": "node scripts/cli-debug.js",
    "debug:help": "node scripts/cli-debug.js help",
    "debug:config": "node scripts/cli-debug.js test-config",
    "debug:fetch": "node scripts/cli-debug.js fetch",
    "mmcheck": "node scripts/magicmirror-check.mjs --devcontainer-only --current",
    "deps:check": "npm outdated && ncu",
    "deps:update": "ncu -u && npm install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "cspell": "^10.0.0",
    "prettier-plugin-jinja-template": "^2.1.0"
  },
  "dependencies": {
    "moment": "^2.30.1",
    "node-ical": "^0.26.0",
    "rrule": "^2.8.1",
    "tsdav": "^2.1.8",
    "webdav": "^5.9.0"
  }
}